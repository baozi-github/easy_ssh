{
  "name": "easy-ssh-desktop",
  "version": "2.1.0",
  "private": true,
  "description": "Windows desktop SSH client with tabs, local files, and saved connection history.",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "dev": "npm run build:main && concurrently -k \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run build:main && vite build",
    "dist": "npm run build && electron-builder --win nsis",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "start": "electron ."
  },
  "build": {
    "appId": "com.easy.sshdesktop",
    "productName": "Easy SSH",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/node-pty/prebuilds/**/*"
    ],
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json",
      "!**/server-profiles.json",
      "!**/*.log",
      "!dev-*.log",
      "!release/**",
      "!node_modules/.cache/**",
      "!node_modules/.vite/**"
    ],
    "win": {
      "icon": "assets/app-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Easy-SSH-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^0.468.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
